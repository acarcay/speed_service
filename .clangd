CompileFlags:
  Add:
    # Enforce C++20 — matches CMakeLists.txt CMAKE_CXX_STANDARD 20.
    - "-std=c++20"

    # Project include root
    - "-I./include"

    # Homebrew general include dir (covers pybind11 symlink + other formulae)
    - "-I/opt/homebrew/include"

    # OpenCV 4 — Homebrew (Apple Silicon)
    - "-I/opt/homebrew/include/opencv4"
    # OpenCV 4 — Homebrew (Intel Mac fallback)
    - "-I/usr/local/include/opencv4"

    # pybind11 — explicit versioned path (Apple Silicon)
    - "-I/opt/homebrew/Cellar/pybind11/3.0.2/include"

    # CPython headers — system Python 3.11 (macOS framework build)
    - "-I/Library/Frameworks/Python.framework/Versions/3.11/include/python3.11"
    # CPython headers — Homebrew Python fallback paths
    - "-I/opt/homebrew/include/python3.12"
    - "-I/opt/homebrew/include/python3.11"

Diagnostics:
  # Suppress IWYU "not used directly" warnings on umbrella headers.
  ClangTidy:
    Remove:
      - misc-include-cleaner
