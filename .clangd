CompileFlags:
  Add:
    # Enforce C++20 — matches CMakeLists.txt CMAKE_CXX_STANDARD 20.
    # Resolves std::is_trivially_copyable_v, std::is_standard_layout_v, etc.
    - "-std=c++20"

    # Project include root
    - "-I./include"

    # OpenCV 4 — Homebrew installs to /opt/homebrew on Apple Silicon (M1/M2/M3)
    - "-I/opt/homebrew/include/opencv4"
    # Intel Mac fallback
    - "-I/usr/local/include/opencv4"

Diagnostics:
  # Suppress IWYU "not used directly" warnings.
  # pipeline.hpp is an umbrella header — re-exporting sub-headers is intentional.
  ClangTidy:
    Remove:
      - misc-include-cleaner
